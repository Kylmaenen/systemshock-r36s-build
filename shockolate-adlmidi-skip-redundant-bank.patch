--- a/src/MusicSrc/MusicDevice.c
+++ b/src/MusicSrc/MusicDevice.c
@@ -184,6 +184,8 @@ typedef struct AdlMidiDevice
 {
     MusicDevice dev;
     struct ADL_MIDIPlayer *adl;
+    int modeInitialized;
+    MusicMode currentMode;
 } AdlMidiDevice;
 
 static int AdlMidiInit(MusicDevice *dev, const unsigned int outputIndex, unsigned samplerate)
@@ -219,8 +221,16 @@ static void AdlMidiSetupMode(MusicDevice *dev, MusicMode mode)
     AdlMidiDevice *adev = (AdlMidiDevice *)dev;
     if (!adev || !adev->dev.isOpen) return;
 
+    if (adev->modeInitialized && adev->currentMode == mode)
+        return;
+
     //Use sound bank 45 for res/sound/sblaster, 0 for res/sound/genmidi
     adl_setBank(adev->adl, (mode == Music_SoundBlaster) ? 45 : 0);
+
+    adev->modeInitialized = 1;
+    adev->currentMode = mode;
+    adev->dev.musicType = (mode == Music_SoundBlaster) ? MUSICTYPE_SBLASTER : MUSICTYPE_GENMIDI;
 }
 
 static void AdlMidiReset(MusicDevice *dev)
@@ -346,6 +356,8 @@ static MusicDevice *createAdlMidiDevice()
     adev->dev.outputIndex = 0;
     adev->dev.deviceType = Music_AdlMidi;
     adev->dev.musicType = MUSICTYPE_SBLASTER;
+    adev->modeInitialized = 0;
+    adev->currentMode = Music_SoundBlaster;
     return &adev->dev;
 }
 
