+static const char *GetSDLRenderDriverSetting(void) {
+    const char *driver = SDL_getenv("SHOCKOLATE_RENDER_DRIVER");
+
+    if (driver == NULL || driver[0] == '\0')
+        driver = SDL_getenv("SDL_RENDER_DRIVER");
+
+    if (driver == NULL || driver[0] == '\0')
+        driver = "opengl";
+
+    return driver;
+}
+
+static bool SDLRenderDriverNeedsOpenGLWindow(const char *driver) {
+    if (driver == NULL)
+        return true;
+
+    return SDL_strcasecmp(driver, "software") != 0;
+}
+
+static SDL_Window *CreateShockWindow(const char *title, bool opengl_window) {
+    Uint32 flags = SDL_WINDOW_HIDDEN | SDL_WINDOW_RESIZABLE | SDL_WINDOW_ALLOW_HIGHDPI;
+
+    if (opengl_window)
+        flags |= SDL_WINDOW_OPENGL;
+
+    return SDL_CreateWindow(title, SDL_WINDOWPOS_CENTERED, SDL_WINDOWPOS_CENTERED, grd_cap->w, grd_cap->h, flags);
+}
+
+static SDL_Renderer *CreateShockRenderer(SDL_Window *target_window, const char *driver, bool allow_software_fallback) {
+    SDL_Renderer *new_renderer;
+
+    if (driver != NULL && driver[0] != '\0')
+        SDL_SetHint(SDL_HINT_RENDER_DRIVER, driver);
+
+    new_renderer = SDL_CreateRenderer(target_window, -1, SDL_RENDERER_PRESENTVSYNC);
+    if (new_renderer != NULL)
+        return new_renderer;
+
+    WARN("SDL_CreateRenderer failed for driver '%s' with vsync: %s", driver, SDL_GetError());
+
+    new_renderer = SDL_CreateRenderer(target_window, -1, 0);
+    if (new_renderer != NULL)
+        return new_renderer;
+
+    WARN("SDL_CreateRenderer failed for driver '%s': %s", driver, SDL_GetError());
+
+    if (!allow_software_fallback)
+        return NULL;
+
+    SDL_SetHint(SDL_HINT_RENDER_DRIVER, "software");
+    new_renderer = SDL_CreateRenderer(target_window, -1, 0);
+    if (new_renderer == NULL)
+        WARN("SDL_CreateRenderer failed for fallback driver 'software': %s", SDL_GetError());
+
+    return new_renderer;
+}
 
