 extern void AudioStreamCallback(void *userdata, unsigned char *stream, int len);
 extern void MusicCallback(void *userdata, Uint8 *stream, int len);
+
+static void ShockAudioCallback(void *userdata, unsigned char *stream, int len) {
+    SDL_AudioStream *as = userdata != NULL ? *(SDL_AudioStream **)userdata : NULL;
+
+    SDL_memset(stream, 0, (size_t)len);
+
+    if (as != NULL && SDL_AudioStreamAvailable(as) > 0)
+        SDL_AudioStreamGet(as, stream, len);
+
+    if (mix_music_in_sdl_device && MusicDev != NULL && MusicDev->isOpen) {
+        Uint8 *music_stream = SDL_malloc((size_t)len);
+        if (music_stream != NULL) {
+            MusicCallback((void *)&MusicDev, music_stream, len);
+            SDL_MixAudioFormat(stream, music_stream, AUDIO_S16SYS, (Uint32)len, SDL_MIX_MAXVOLUME);
+            SDL_free(music_stream);
+        }
+    }
+}
 
